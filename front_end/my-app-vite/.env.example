# ─────────────────────────────────────────────────────────────────────
# Frontend environment variables (Vite)
#
# Copy this file to `.env.local` (gitignored via *.local) and fill in
# the values. All variables must be prefixed with VITE_ to be exposed
# to the client bundle.
# ─────────────────────────────────────────────────────────────────────

# Base URL of the backend API.
VITE_API_URL=http://localhost:3036/api

# Stripe publishable key (safe to expose in the browser).
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
