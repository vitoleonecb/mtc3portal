{
    "info": {
    "name": "Create RSVP",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
    {
        "name": "POST RSVP for Workshop",
        "request": {
            "method": "POST",
            "header": [
                {
                    "key": "Content-Type",
                    "value": "application/json"
                },
                {
                    "key": "Authorization",
                    "value": "Bearer {{access_token}}"
                }
            ],
            "body": {
                "mode": "raw",
                "raw": "{\"workshop_id\": {{workshop_id}}, \"user_id\": {{user_id}}}"
            },   
            "url": {
                "raw": "http://localhost:3036/workshops/rsvp/create",
                "protocol": "http",
                "host": ["localhost"],
                "port": "3036",
                "path": ["workshops","rsvp","create"]
            }
        }
    }   
    ]
  }
  