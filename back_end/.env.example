# ─────────────────────────────────────────────────────────────────────
# Backend environment variables
#
# Copy this file to `.env` (which is gitignored) and fill in the values.
# Every variable below is read from process.env at runtime.
# ─────────────────────────────────────────────────────────────────────

# ── HTTP server ──────────────────────────────────────────────────────
PORT=3036

# Public URL of the frontend, used to build links in outgoing emails / SMS.
APP_BASE_URL=http://localhost:5173

# ── MySQL ────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=mtc3portal
DB_PASSWORD=
DB_DATABASE=mtc3portal

# ── Auth ─────────────────────────────────────────────────────────────
# Long random string used to sign JWTs (login, password reset, email confirm).
ACCESS_TOKEN_SECRET=

# ── Stripe (memberships + showcase tickets) ──────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_MEMBERSHIP_PRICE_ID=price_xxx

# ── Postmark (transactional email) ───────────────────────────────────
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=noreply@example.com

# ── Twilio (SMS notifications) ───────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── OpenAI (prompt-level AI analysis) ────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# ── Script-only (used by back_end/script_testing) ────────────────────
# Base URL for the running API and a seed user's credentials so the
# response-seeding scripts can authenticate.
API_BASE=http://localhost:3036/api
EMAIL=
PASSWORD=
